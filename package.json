{
    "name": "flowchat-docs",
    "version": "1.0.0",
    "description": "Professional multi-LLM chat platform documentation",
    "private": true,
    "homepage": "https://flowchats.org",
    "repository": {
        "type": "git",
        "url": "https://github.com/NishantGits/flow-docs"
    },
    "keywords": [
        "flowchat",
        "multi-llm",
        "chat",
        "ai",
        "documentation",
        "docusaurus"
    ],
    "author": {
        "name": "Nishant Lodhi",
        "email": "contact@flowchats.org",
        "url": "https://flowchats.org"
    },
    "license": "UNLICENSED",
    "engines": {
        "node": ">=18.0",
        "npm": ">=8.0"
    },
    "scripts": {
        "docusaurus": "docusaurus",
        "start": "docusaurus start",
        "build": "docusaurus build",
        "swizzle": "docusaurus swizzle",
        "deploy": "docusaurus deploy",
        "clear": "docusaurus clear",
        "serve": "docusaurus serve",
        "typecheck": "tsc --noEmit",
        "format": "prettier --write \"src/**/*.{js,jsx,ts,tsx,css,md,mdx}\"",
        "format:check": "prettier --check \"src/**/*.{js,jsx,ts,tsx,css,md,mdx}\"",
        "lint": "eslint src --fix --max-warnings=0",
        "lint:check": "eslint src --max-warnings=0",
        "stylelint": "stylelint \"src/**/*.css\" --fix",
        "stylelint:check": "stylelint \"src/**/*.css\"",
        "write-translations": "docusaurus write-translations",
        "write-heading-ids": "docusaurus write-heading-ids",
        "mdx-check": "npx docusaurus-mdx-checker",
        "validate": "npm run format:check && npm run lint:check && npm run typecheck"
    },
    "dependencies": {
        "@docusaurus/core": "^3.5.2",
        "@docusaurus/preset-classic": "^3.5.2",
        "@docusaurus/theme-mermaid": "^3.5.2",
        "@mdx-js/react": "^3.0.1",
        "@tailwindcss/postcss": "^4.0.3",
        "autoprefixer": "^10.4.20",
        "clsx": "^2.1.1",
        "marked": "^17.0.1",
        "postcss": "^8.4.47",
        "prism-react-renderer": "^2.4.0",
        "react": "^18.3.1",
        "react-dom": "^18.3.1",
        "react-fluentui-emoji": "^1.3.0",
        "sass": "^1.79.3",
        "tailwindcss": "^3.4.13"
    },
    "devDependencies": {
        "@docusaurus/eslint-plugin": "^3.5.2",
        "@docusaurus/module-type-aliases": "^3.5.2",
        "@docusaurus/tsconfig": "^3.5.2",
        "@docusaurus/types": "^3.5.2",
        "@typescript-eslint/eslint-plugin": "^7.18.0",
        "@typescript-eslint/parser": "^7.0.0",
        "prettier": "^3.3.3",
        "prettier-plugin-tailwindcss": "^0.6.8",
        "stylelint": "^16.9.0",
        "stylelint-config-html": "^1.1.0",
        "stylelint-config-standard": "^36.0.1",
        "typescript": "^5.5.4",
        "typescript-eslint": "^8.7.0"
    },
    "browserslist": {
        "production": [
            ">0.5%",
            "not dead",
            "not op_mini all"
        ],
        "development": [
            "last 3 chrome version",
            "last 3 firefox version",
            "last 5 safari version"
        ]
    }
}
